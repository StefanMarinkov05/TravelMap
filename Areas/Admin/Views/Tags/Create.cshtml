@model TravelMap.Models.Tag

@{
    ViewData["Title"] = "Нов Таг";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0 rounded-4 p-4 p-lg-5">
                <div class="text-center mb-4">
                    <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex p-3 mb-3">
                        <i class="bi bi-tag-fill text-primary fs-2"></i>
                    </div>
                    <h2 class="fw-bold">Нов Таг</h2>
                    <p class="text-muted small">Добавете нова категория за дестинациите</p>
                </div>
                <hr />
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                    <div class="form-group mb-4">
                        <label asp-for="Name" class="form-label fw-bold small">Име на тага</label>
                        <input asp-for="Name" class="form-control rounded-pill px-3" placeholder="напр. Исторически" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill py-2 fw-bold shadow-sm">Създай</button>
                        <a asp-controller="DestinationSpecifications" asp-action="Index" class="btn btn-light rounded-pill py-2">Назад към списъка</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}