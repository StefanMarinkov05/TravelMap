@model TravelMap.Models.Catalog

@{
    ViewData["Title"] = "Редактиране на каталог";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-dark py-3">
                    <h4 class="text-white mb-0 fw-bold">📝 Редактирай каталог</h4>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold small text-uppercase">Име на каталога</label>
                            <input asp-for="Name" class="form-control border-2 rounded-3" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="UserId" class="form-label fw-bold small text-uppercase">Потребител</label>
                            <select asp-for="UserId" class="form-select border-2" asp-items="ViewBag.UserId"></select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label fw-bold small text-uppercase">Бележки</label>
                            <textarea asp-for="Notes" class="form-control border-2 rounded-3" rows="3"></textarea>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input class="form-check-input" type="checkbox" asp-for="IsPublic" id="isPublicCheck">
                            <label class="form-check-label fw-bold" for="isPublicCheck">Публично достъпен</label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary rounded-pill px-4 flex-grow-1 fw-bold shadow-sm">Запази промените</button>
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4">Отказ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
