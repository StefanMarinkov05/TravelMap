@model IEnumerable<TravelMap.Models.Catalog>

@{
    ViewData["Title"] = "Каталози";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">📂 Управление на каталози</h2>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>Нов Каталог
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">@Html.DisplayNameFor(model => model.Name)</th>
                        <th>Собственик</th>
                        <th>Статус</th>
                        <th>Бележки</th>
                        <th class="text-end pe-4">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@item.Name</td>
                            <td>
                                <span class="badge bg-light text-dark border rounded-pill px-3">
                                    <i class="bi bi-person me-1"></i> @item.ApplicationUser?.Email
                                </span>
                            </td>
                            <td>
                                @if (item.IsPublic)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3">Публичен</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill px-3">Личен</span>
                                }
                            </td>
                            <td class="text-muted small">@item.Notes</td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-white btn-sm border-end" title="Редактиране">
                                        <i class="bi bi-pencil text-primary"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-white btn-sm border-end" title="Детайли">
                                        <i class="bi bi-eye text-info"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-white btn-sm" title="Изтриване">
                                        <i class="bi bi-trash text-danger"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>