@model TravelMap.Models.Catalog

@{
    ViewData["Title"] = "Нов Каталог";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Каталози</a></li>
                    <li class="breadcrumb-item active">Създаване</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary py-3">
                    <h4 class="text-white mb-0 fw-bold"><i class="bi bi-folder-plus me-2"></i>Нов Каталог</h4>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold small text-uppercase text-muted">Име на каталога</label>
                            <input asp-for="Name" class="form-control border-2 rounded-3 shadow-sm" placeholder="напр. Любими плажове" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="UserId" class="form-label fw-bold small text-uppercase text-muted">Присвои на потребител</label>
                            <select asp-for="UserId" class="form-select border-2 rounded-3 shadow-sm" asp-items="ViewBag.UserId">
                                <option value="">-- Изберете потребител --</option>
                            </select>
                            <span asp-validation-for="UserId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label fw-bold small text-uppercase text-muted">Допълнителни бележки</label>
                            <textarea asp-for="Notes" class="form-control border-2 rounded-3 shadow-sm" rows="3" placeholder="Кратко описание..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                        <div class="form-check form-switch mb-4 mt-4">
                            <input class="form-check-input" type="checkbox" asp-for="IsPublic" id="isPublicSwitch">
                            <label class="form-check-label fw-bold" for="isPublicSwitch">Публичен каталог</label>
                            <div class="form-text small">Ако е изключено, каталогът ще е видим само за собственика.</div>
                        </div>

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm">
                                <i class="bi bi-check-circle me-2"></i>Създай каталог
                            </button>
                            <a asp-action="Index" class="btn btn-light rounded-pill">Отказ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

