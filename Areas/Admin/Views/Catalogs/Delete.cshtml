@model TravelMap.Models.Catalog

@{
    ViewData["Title"] = "Изтриване на каталог";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden border-top border-danger border-5">
                <div class="card-body p-4 p-md-5 text-center">
                    <div class="mb-4">
                        <i class="bi bi-exclamation-triangle text-danger" style="font-size: 4rem;"></i>
                    </div>

                    <h2 class="fw-bold text-dark mb-2">Изтриване?</h2>
                    <p class="text-muted mb-4">Сигурни ли сте, че искате да изтриете каталога <strong>"@Model.Name"</strong>? Това действие е необратимо.</p>

                    <div class="bg-light rounded-4 p-4 mb-4 text-start">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Собственик:</span>
                            <span class="fw-bold small">@Model.ApplicationUser?.Email</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted small">Дестинации вътре:</span>
                            <span class="badge bg-danger rounded-pill">@Model.CatalogDestinations?.Count</span>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold shadow-sm">
                                <i class="bi bi-trash me-2"></i>Потвърди изтриването
                            </button>
                            <a asp-action="Index" class="btn btn-light rounded-pill">Не, върни ме обратно</a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="alert alert-warning mt-4 rounded-4 shadow-sm border-0 small">
                <i class="bi bi-info-circle me-2"></i>
                <strong>Внимание:</strong> Изтриването на каталога няма да изтрие самите дестинации, а само тяхната организация в тази папка.
            </div>
        </div>
    </div>
</div>