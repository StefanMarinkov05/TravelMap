@model TravelMap.Models.Article

@{
    ViewData["Title"] = "Изтриване на статия";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card p-5 border-0 shadow-lg rounded-5 bg-white">
                <div class="mb-4 text-danger bg-danger bg-opacity-10 d-inline-block p-4 rounded-circle">
                    <i class="bi bi-file-earmark-x display-3"></i>
                </div>

                <h2 class="fw-bold mb-3">Изтриване на статия</h2>
                <p class="text-secondary mb-4 px-lg-5">
                    Сигурни ли сте, че искате да изтриете статията <br>
                    <strong class="text-dark">"@Model.Title"</strong>? <br>
                    Това действие е необратимо.
                </p>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger rounded-pill py-2 fw-bold shadow-sm">Да, изтрий окончателно</button>
                        <a asp-action="Index" class="btn btn-light rounded-pill py-2">Не, запази статията</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>