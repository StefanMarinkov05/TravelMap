@model TravelMap.Models.Article

@{
    ViewData["Title"] = "Редактиране на статия";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 p-4 p-lg-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold mb-0 text-warning"><i class="bi bi-pencil-square me-2"></i>Редактирай</h2>
                    <span class="text-muted small">ID: #@Model.Id</span>
                </div>
                <hr class="mb-5">

                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group mb-4">
                        <label asp-for="Title" class="form-label fw-bold small text-uppercase">Заглавие</label>
                        <input asp-for="Title" class="form-control rounded-pill px-4 border-warning border-opacity-25" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="DestinationId" class="form-label fw-bold small text-uppercase">Дестинация</label>
                        <select asp-for="DestinationId" class="form-select rounded-pill px-4 border-warning border-opacity-25" asp-items="ViewBag.DestinationId"></select>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Description" class="form-label fw-bold small text-uppercase">Резюме</label>
                        <textarea asp-for="Description" class="form-control rounded-4 px-4 border-warning border-opacity-25" rows="2"></textarea>
                    </div>

                    <div class="form-group mb-5">
                        <label asp-for="Content" class="form-label fw-bold small text-uppercase">Текст на статията</label>
                        <textarea asp-for="Content" class="form-control rounded-4 px-4 border-warning border-opacity-25" rows="12"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning rounded-pill px-5 fw-bold shadow-sm">Запази промените</button>
                        <a asp-action="Index" class="btn btn-light rounded-pill px-4">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}