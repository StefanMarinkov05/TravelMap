@model TravelMap.Models.Article

@{
    ViewData["Title"] = "Писане на статия";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 p-4 p-lg-5">
                <h2 class="fw-bold mb-4"><i class="bi bi-pen me-2 text-primary"></i>Нова статия</h2>
                <hr class="mb-5">

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

                    <div class="form-group mb-4">
                        <label asp-for="Title" class="form-label fw-bold">Заглавие</label>
                        <input asp-for="Title" class="form-control form-control-lg border-0 bg-light rounded-4 px-4" placeholder="Въведете заглавие..." />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-12">
                            <label asp-for="DestinationId" class="form-label fw-bold">Свързана дестинация</label>
                            <select asp-for="DestinationId" class="form-select border-0 bg-light rounded-pill px-4" asp-items="ViewBag.DestinationId"></select>
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Description" class="form-label fw-bold">Кратко резюме</label>
                        <textarea asp-for="Description" class="form-control border-0 bg-light rounded-4 px-4" rows="2" placeholder="За какво се разказва в статията?"></textarea>
                    </div>

                    <div class="form-group mb-5">
                        <label asp-for="Content" class="form-label fw-bold">Съдържание</label>
                        <textarea asp-for="Content" class="form-control border-0 bg-light rounded-4 px-4" rows="10" placeholder="Започнете да пишете своята история тук..."></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold py-2 shadow-sm">Публикувай</button>
                        <a asp-action="Index" class="btn btn-light rounded-pill px-4 py-2">Отказ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}