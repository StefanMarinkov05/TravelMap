@model TravelMap.Models.Country

@{
    ViewData["Title"] = "Добави Държава";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0 rounded-4 p-4 p-lg-5">
                <div class="text-center mb-4">
                    <i class="bi bi-globe-europe-africa text-primary display-4"></i>
                    <h2 class="fw-bold mt-3">Нова Държава</h2>
                </div>
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                    <div class="form-group mb-4">
                        <label asp-for="Name" class="form-label fw-bold small">Име на държавата</label>
                        <input asp-for="Name" class="form-control rounded-pill px-3" placeholder="напр. България" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill py-2 fw-bold">Запази</button>
                        <a asp-controller="DestinationSpecifications" asp-action="Index" class="btn btn-light rounded-pill py-2">Отказ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
