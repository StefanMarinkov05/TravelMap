@model TravelMap.Models.ApplicationUser

@{
    ViewData["Title"] = "Изтриване на потребител";
}

<div class="container py-5">
    <div class="row justify-content-center text-center">
        <div class="col-md-5">
            <div class="card p-5 border-0 shadow-lg rounded-5">
                <div class="text-danger mb-4 bg-danger bg-opacity-10 d-inline-block p-4 rounded-circle mx-auto">
                    <i class="bi bi-person-x display-3"></i>
                </div>

                <h2 class="fw-bold mb-3">Премахване на достъп</h2>
                <p class="text-secondary mb-4">
                    Сигурни ли сте, че искате да изтриете потребителя <br>
                    <strong class="text-dark">@Model.FirstName @Model.LastName</strong>?
                </p>

                <div class="alert alert-light border-0 small text-start mb-4">
                    <i class="bi bi-info-circle me-2"></i> Имейл: @Model.Email
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger rounded-pill py-2 fw-bold shadow-sm">Да, изтрий потребителя</button>
                        <a asp-action="Index" class="btn btn-light rounded-pill py-2">Върни се обратно</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>