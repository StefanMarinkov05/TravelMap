@model TravelMap.Models.ApplicationUser

@{
    ViewData["Title"] = "Редактиране на потребител";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 rounded-4 p-4 p-lg-5 bg-white">
                <div class="text-center mb-4">
                    <div class="bg-warning bg-opacity-10 text-warning d-inline-block p-3 rounded-circle mb-3">
                        <i class="bi bi-person-gear fs-1"></i>
                    </div>
                    <h2 class="fw-bold">@ViewData["Title"]</h2>
                    <p class="text-muted small">Промяна на данните за @Model.FirstName</p>
                </div>

                <hr class="mb-4 opacity-75">

                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label fw-bold small text-muted">Име</label>
                            <input asp-for="FirstName" class="form-control rounded-pill px-3 border-light-subtle shadow-sm" placeholder="Име" required />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label fw-bold small text-muted">Фамилия</label>
                            <input asp-for="LastName" class="form-control rounded-pill px-3 border-light-subtle shadow-sm" placeholder="Фамилия" required />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Email" class="form-label fw-bold small text-muted">Имейл адрес</label>
                        <input asp-for="Email" class="form-control rounded-pill px-3 border-light-subtle shadow-sm" placeholder="email@example.com" required />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="PhoneNumber" class="form-label fw-bold small text-muted">Телефонен номер</label>
                        <input asp-for="PhoneNumber" class="form-control rounded-pill px-3 border-light-subtle shadow-sm" placeholder="+359..." required />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2 pt-2">
                        <button type="submit" class="btn btn-warning rounded-pill py-2 fw-bold text-dark shadow-sm">
                            <i class="bi bi-check-lg me-1"></i> Запази промените
                        </button>
                        <a asp-action="Index" class="btn btn-light rounded-pill py-2 text-secondary">
                            Отказ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}