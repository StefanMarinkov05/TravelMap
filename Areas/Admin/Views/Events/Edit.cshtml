@model TravelMap.Models.Event

@{
    ViewData["Title"] = "Редактиране на събитие";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 p-4 p-lg-5">
                <h2 class="fw-bold mb-4 text-center text-warning">Редактирай Събитие</h2>
                <hr class="mb-4" />
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Име</label>
                        <input asp-for="Name" class="form-control rounded-pill px-3" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Description" class="form-label fw-bold">Описание</label>
                        <textarea asp-for="Description" class="form-control rounded-4 px-3" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Date" class="form-label fw-bold">Дата</label>
                            <input asp-for="Date" type="date" class="form-control rounded-pill px-3" />
                            <span asp-validation-for="Date" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DestinationId" class="form-label fw-bold">Дестинация</label>
                            <select asp-for="DestinationId" class="form-select rounded-pill px-3" asp-items="ViewBag.DestinationId"></select>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-warning rounded-pill py-2 fw-bold shadow-sm">Запази промените</button>
                        <a asp-action="Index" class="btn btn-light rounded-pill py-2">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}