@model TravelMap.Models.Destination

@{
    ViewData["Title"] = "Детайли за дестинация";
    var images = Model.Images?.ToList() ?? new List<TravelMap.Models.DestinationImage>();
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Дестинации</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="row g-0">
            <div class="col-lg-6 bg-dark">
                @if (images.Any())
                {
                    <div id="destinationCarousel" class="carousel slide h-100 shadow-sm" data-bs-ride="carousel">
                        @if (images.Count > 1)
                        {
                            <div class="carousel-indicators">
                                @for (int i = 0; i < images.Count; i++)
                                {
                                    <button type="button" data-bs-target="#destinationCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "")"></button>
                                }
                            </div>
                        }

                        <div class="carousel-inner h-100">
                            @for (int i = 0; i < images.Count; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "") h-100" style="min-height: 450px;">
                                    <img src="@images[i].ImageUrl" class="d-block w-100 h-100 shadow-sm" style="object-fit: cover;" alt="@Model.Name">
                                </div>
                            }
                        </div>

                        @if (images.Count > 1)
                        {
                            <button class="carousel-control-prev" type="button" data-bs-target="#destinationCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon p-3 bg-dark bg-opacity-25 rounded-circle" aria-hidden="true"></span>
                                <span class="visually-hidden">Предишна</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#destinationCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon p-3 bg-dark bg-opacity-25 rounded-circle" aria-hidden="true"></span>
                                <span class="visually-hidden">Следваща</span>
                            </button>
                        }

                        <div class="position-absolute top-0 start-0 m-3" style="z-index: 5;">
                            <span class="badge bg-primary rounded-pill px-3 shadow-lg">@Model.Category?.Name</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center h-100" style="min-height: 400px;">
                        <div class="text-center">
                            <i class="bi bi-image text-secondary display-1"></i>
                            <p class="text-muted mt-2">Няма налични снимки</p>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-6 p-4 p-lg-5 bg-white">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h1 class="fw-bold mb-1 text-dark">@Model.Name</h1>
                        <p class="fs-5 text-muted">
                            <i class="bi bi-geo-alt-fill text-danger me-1"></i> @Model.Region, @Model.Country?.Name
                        </p>
                    </div>
                    <div class="text-end">
                        <div class="bg-warning bg-opacity-10 text-warning rounded-4 px-3 py-2 fw-bold border border-warning border-opacity-25">
                            <i class="bi bi-star-fill me-1"></i> @Model.Popularity
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mb-4">
                    @if (Model.Tags != null)
                    {
                        foreach (var tag in Model.Tags)
                        {
                            <span class="badge bg-light text-primary border rounded-pill px-3">#@tag.Name</span>
                        }
                    }
                </div>

                <hr class="my-4 opacity-25">

                <div class="row g-4 mb-5">
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3">
                                <i class="bi bi-person-circle text-primary fs-4"></i>
                            </div>
                            <div>
                                <label class="text-muted small d-block">Автор</label>
                                <span class="fw-bold">@(Model.Author?.FirstName ?? "Система")</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center">
                            <div class="bg-success bg-opacity-10 p-2 rounded-3 me-3">
                                <i class="bi bi-calendar-check text-success fs-4"></i>
                            </div>
                            <div>
                                <label class="text-muted small d-block">Добавена на</label>
                                <span class="fw-bold">@Model.CreationDate.ToString("dd MMM yyyy")</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="fw-bold mb-2 text-dark"><i class="bi bi-info-circle me-2"></i>Описание</label>
                        <p class="text-secondary lh-lg" style="text-align: justify;">
                            @(string.IsNullOrEmpty(Model.Description) ? "Няма налично описание за тази дестинация." : Model.Description)
                        </p>
                    </div>
                </div>

                <div class="d-flex gap-2 pt-3 border-top">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm">
                        <i class="bi bi-pencil-square me-2"></i>Редактиране
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                        <i class="bi bi-arrow-left me-2"></i>Назад
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .carousel-item img {
            transition: transform 0.5s ease;
        }

        .carousel-indicators [button] {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin: 0 5px;
        }

        .carousel-fade .carousel-item {
            transition-duration: 0.6s;
        }
    </style>
}