@page
@model LogoutModel
@{
    ViewData["Title"] = "Изход";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow rounded-4 p-5">
                <i class="bi bi-door-open fs-1 text-warning mb-3"></i>
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <h2 class="fw-bold mb-4">Сигурни ли сте, че искате да излезете?</h2>
                    <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                        <button type="submit" class="btn btn-danger btn-lg rounded-pill px-5 shadow-sm">Да, излез</button>
                    </form>
                    <a href="/" class="btn btn-link mt-3 text-muted">Остани в профила</a>
                }
                else
                {
                    <h2 class="fw-bold text-success mb-3">Излязохте успешно!</h2>
                    <p class="text-muted">Благодарим ви, че използвахте нашата карта. Ще се радваме да се върнете скоро!</p>
                    <div class="mt-4">
                        <a asp-page="./Login" class="btn btn-primary rounded-pill px-4">Влез отново</a>
                        <a href="/" class="btn btn-outline-secondary rounded-pill px-4 ms-2">Към началната страница</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>