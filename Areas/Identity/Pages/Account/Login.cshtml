@page
@model LoginModel
@{
    ViewData["Title"] = "Вход";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-dark py-3 text-center">
                    <h3 class="text-white mb-0 fw-bold"><i class="bi bi-box-arrow-in-right me-2"></i>Вход в системата</h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control rounded-3" autocomplete="username" placeholder="name@example.com" />
                            <label asp-for="Input.Email">Имейл</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" type="password" class="form-control rounded-3" autocomplete="current-password" placeholder="password" />
                            <label asp-for="Input.Password">Парола</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="checkbox mb-4 d-flex justify-content-between">
                            <label asp-for="Input.RememberMe" class="form-label small text-muted">
                                <input class="form-check-input me-1" asp-for="Input.RememberMe" />
                                Запомни ме
                            </label>
                            <a id="forgot-password" asp-page="./ForgotPassword" class="small text-decoration-none">Забравена парола?</a>
                        </div>

                        <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary rounded-pill fw-bold shadow-sm">Влез</button>

                        <div class="text-center mt-4 border-top pt-3">
                            <p class="small text-muted mb-0">Нямате профил? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-bold">Регистрирайте се</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}