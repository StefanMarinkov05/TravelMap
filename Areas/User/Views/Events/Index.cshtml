@model IEnumerable<TravelMap.Models.Event>

@{
    ViewData["Title"] = "Предстоящи Събития";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h1 class="display-4 fw-bold text-dark mb-0">Предстоящи Събития</h1>
            <p class="text-secondary lead mb-0">Не пропускай вълнуващите моменти</p>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-sm-12 col-md-6 col-lg-4 col-xl-3">
                <div class="card h-100 border-0 shadow-sm rounded-4 flashcard-hover overflow-hidden bg-white d-flex flex-column">

                    <div class="position-relative" style="height: 180px;">
                        @{
                            var eventImg = Url.Content(item.Destination?.Images?.FirstOrDefault()?.ImageUrl ?? "~/images/destinations/default.jpg");
                        }
                        <img src="@eventImg" class="w-100 h-100 object-fit-cover" alt="@item.Name">

                    </div>

                    <div class="card-body p-4 d-flex flex-column flex-grow-1">
                        <div class="mb-2">
                            <span class="badge bg-primary-subtle text-primary rounded-pill small px-3">
                                <i class="bi bi-geo-alt-fill me-1"></i> @item.Destination?.Country?.Name, @item.Destination?.Name
                            </span>
                        </div>

                        <h5 class="fw-bold mb-2 title-clamp">@item.Name</h5>

                        <p class="text-secondary small line-clamp-2 mb-4">
                            @((item.Description?.Length > 50 ? item.Description.Substring(0, 47) + "..." : item.Description)?.PadRight(50, '\u00A0'))
                        </p>

                        <div class="mt-auto">
                            <div class="d-flex align-items-center mb-3 text-primary fw-bold">
                                <i class="bi bi-calendar3 me-2"></i>
                                <span>@item.Date.ToString("D")</span>
                            </div>

                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary w-100 rounded-pill fw-bold">
                                Виж повече
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
<style>
    .flashcard-hover {
        transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .flashcard-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.12) !important;
        }

    .object-fit-cover {
        object-fit: cover;
    }

    .title-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 3rem;
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 2.5rem;
    }

    .glass-badge {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(5px);
        color: #000;
        border: 1px solid rgba(255,255,255,0.3);
        font-weight: bold;
    }
</style>