@{
    ViewData["Title"] = "Полезни съвети";
}

<div class="container py-5">
    <div class="row mb-5 justify-content-center text-center">
        <div class="col-lg-8">
            <h1 class="display-3 fw-bold text-primary mb-3">Съвети за Пътешественици</h1>
            <p class="lead text-muted">Малките неща, които правят голямото пътуване по-лесно и приятно.</p>
            <div class="h-1 bg-primary w-25 mx-auto rounded"></div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="d-flex align-items-start p-4 bg-white shadow-sm rounded-4 border-start border-primary border-5">
                <i class="bi bi-briefcase text-primary fs-1 me-4"></i>
                <div>
                    <h4 class="fw-bold">Опаковай умно</h4>
                    <p class="text-muted mb-0">Винаги слагай най-тежките предмети най-отдолу. Използвай вакуумни торби за обемни дрехи.</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="d-flex align-items-start p-4 bg-white shadow-sm rounded-4 border-start border-success border-5">
                <i class="bi bi-shield-check text-success fs-1 me-4"></i>
                <div>
                    <h4 class="fw-bold">Сигурност на документите</h4>
                    <p class="text-muted mb-0">Направи дигитални копия на паспорта и застраховката си и ги съхранявай в облака.</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="d-flex align-items-start p-4 bg-white shadow-sm rounded-4 border-start border-info border-5">
                <i class="bi bi-translate text-info fs-1 me-4"></i>
                <div>
                    <h4 class="fw-bold">Научи местния език</h4>
                    <p class="text-muted mb-0">Научи поне "Благодаря" и "Здравей". Местните хора оценяват усилията и ще бъдат по-любезни.</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="d-flex align-items-start p-4 bg-white shadow-sm rounded-4 border-start border-warning border-5">
                <i class="bi bi-wallet2 text-warning fs-1 me-4"></i>
                <div>
                    <h4 class="fw-bold">Бюджетни пътувания</h4>
                    <p class="text-muted mb-0">Храни се там, където се хранят местните. Избягвай ресторанти с менюта на 5 езика пред входа.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 p-5 bg-dark text-white rounded-5 shadow-lg">
        <div class="row align-items-center">
            <div class="col-lg-5 text-center text-lg-start mb-4 mb-lg-0">
                <h2 class="fw-bold mb-3">Имаш свой съвет?</h2>
                <p class="text-secondary mb-0">Сподели го с нашата общност и стани част от нашия блог!</p>
                <div class="mt-3 d-none d-lg-block">
                    <i class="bi bi-lightbulb text-warning display-4"></i>
                </div>
            </div>

            <div class="col-lg-7">
                <form asp-controller="Articles" asp-action="QuickSubmit" method="post" class="bg-white p-4 rounded-4 shadow-sm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-dark small fw-bold">Твоето име</label>
                            <input type="text" name="AuthorName" class="form-control bg-light border-0" placeholder="Име..." required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-dark small fw-bold">Тема</label>
                            <input type="text" name="Title" class="form-control bg-light border-0" placeholder="Заглавие на съвета..." required>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-dark small fw-bold">Твоят съвет</label>
                            <textarea name="Content" class="form-control bg-light border-0" rows="3" placeholder="Напиши нещо вдъхновяващо..." required></textarea>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold py-2 shadow-sm">
                                <i class="bi bi-send me-2"></i>Изпрати съвет
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <style>
        .form-control:focus {
            background-color: #fff !important;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
            border: 1px solid #0d6efd !important;
        }
    </style>
</div>