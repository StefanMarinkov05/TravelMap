@model TravelMap.Models.Catalog

@{
    ViewData["Title"] = "Редактиране";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 p-4 p-lg-5">
                <h1 class="fw-bold mb-4">Редактирай</h1>
                <hr />
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group mb-3">
                        <label asp-for="Name" class="control-label fw-bold mb-2">Име</label>
                        <input asp-for="Name" class="form-control rounded-pill px-3" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group form-check mb-3">
                        <label class="form-check-label">
                            <input class="form-check-input" asp-for="IsPublic" /> @Html.DisplayNameFor(model => model.IsPublic)
                        </label>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Notes" class="control-label fw-bold mb-2">Бележки</label>
                        <textarea asp-for="Notes" class="form-control rounded-4 px-3" rows="3"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>

                    <div class="form-group d-flex gap-2">
                        <input type="submit" value="Запази" class="btn btn-primary rounded-pill px-4" />
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}