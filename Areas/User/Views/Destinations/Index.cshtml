@model IEnumerable<TravelMap.Models.Destination>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject TravelMap.TravelMapContext _context

@{
    ViewData["Title"] = "Дестинации";
    var allTags = Model.SelectMany(d => d.Tags).Select(t => t.Name).Distinct().OrderBy(t => t).ToList();

    // catalogue logic for current user
    var user = await UserManager.GetUserAsync(User);
    var userCatalogs = user != null
        ? _context.Catalogs.Where(c => c.UserId == user.Id).ToList()
        : new List<TravelMap.Models.Catalog>();
}

<div class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-5 gap-3">
        <div>
            <h1 class="display-4 fw-bold text-dark mb-0">Открий своето следващо приключение</h1>
        </div>

    </div>

    <div class="bg-white p-4 rounded-4 shadow-sm border mb-5">
        <div class="row g-4">
            <div class="col-lg-7">
                <label class="form-label small fw-bold text-muted text-uppercase">Търсене</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 rounded-start-pill ps-3">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control border-start-0 rounded-end-pill py-2 bg-light"
                           placeholder="Име, държава, регион или тема...">
                </div>
            </div>

            <div class="col-lg-5 d-flex align-items-end justify-content-lg-end">
                <div class="dropdown w-100 w-lg-auto">
                    <button class="btn btn-outline-secondary rounded-pill dropdown-toggle px-4 w-100 shadow-sm" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-sort-down me-2"></i>Сортиране
                    </button>
                    <ul class="dropdown-menu shadow border-0 rounded-3">
                        <li><a class="dropdown-item" asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]">Име</a></li>
                        <li><a class="dropdown-item" asp-action="Index" asp-route-sortOrder="@ViewData["CountrySortParm"]">Държава</a></li>
                        <li><a class="dropdown-item" asp-action="Index" asp-route-sortOrder="@ViewData["DateSortParm"]">Дата</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item fw-bold text-primary" asp-action="Index" asp-route-sortOrder="@ViewData["PopSortParm"]">
                                <i class="bi bi-fire me-2"></i>Популярност
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="col-12 mt-3">
                <label class="form-label small fw-bold text-muted text-uppercase mb-2">Бързи филтри (Тагове)</label>
                <div class="d-flex flex-wrap gap-2" id="tagsCloud">
                    <button onclick="clearFilters()" class="btn btn-sm btn-dark rounded-pill px-3 tag-filter-btn active" data-tag="all">
                        Всички
                    </button>
                    @foreach (var tagName in allTags)
                    {
                        <button onclick="filterByTag('@tagName.ToLower()', this)"
                                class="btn btn-sm btn-outline-primary rounded-pill px-3 tag-filter-btn"
                                data-tag="@tagName.ToLower()">
                            #@tagName
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4" id="destinationsGrid">
        @foreach (var item in Model)
        {
            var authorName = item.Author != null ? $"{item.Author.FirstName} {item.Author.LastName}" : "Система";
            var searchData = $"{item.Name} {item.Region} {item.Country?.Name} {authorName} {string.Join(" ", item.Tags.Select(t => t.Name))}".ToLower();

            <div class="col-sm-12 col-md-6 col-lg-4 col-xl-3 destination-card" data-search="@searchData">
                <div class="card h-100 border-0 shadow-sm rounded-4 flashcard-hover overflow-hidden bg-white">
                    <div class="position-relative" style="height: 200px;">
                        <img src="@Url.Content(item.Images?.FirstOrDefault()?.ImageUrl ?? "~/images/destinations/default.jpg")"
                             class="w-100 h-100 object-fit-cover"
                             alt="@item.Name">

                        <div class="position-absolute top-0 start-0 m-2 d-flex flex-wrap gap-1">
                            @foreach (var tag in item.Tags)
                            {
                                <span class="badge glass-badge rounded-pill">#@tag.Name</span>
                            }
                        </div>

                        <div class="position-absolute bottom-0 end-0 m-3">
                            <span class="badge glass-badge rounded-pill px-2 small">
                                <i class="bi bi-camera me-1"></i> @item.ImageCount
                            </span>
                        </div>
                    </div>

                    <div class="card-body p-4 d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="text-muted small fw-bold title-clamp"><i class="bi bi-geo-alt text-danger"></i> @item.Country?.Name, @item.Region</span>
                            <span class="badge bg-light text-primary border rounded-pill" title="Брой добавяния в каталози">
                                <i class="bi bi-heart-fill">@item.Popularity</i>
                            </span>
                        </div>
                        <h5 class="fw-bold mb-3">@item.Name</h5>
                        <div class="text-muted small">@item.Category?.Name</div>
                        <div class="mb-3">
                            <span class="badge bg-info bg-opacity-10 text-info border-0 rounded-pill small fw-normal" style="font-size: 0.75rem;">
                                <i class="bi bi-person-circle me-1"></i> @authorName
                            </span>
                        </div>

                        <p class="text-secondary small line-clamp-2">@item.Description</p>

                        <div class="dropdown mt-3 mb-3">
                            <button class="btn btn-sm btn-outline-dark w-100 rounded-pill dropdown-toggle fw-bold" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-folder-plus me-1"></i> Колекции
                            </button>
                            <ul class="dropdown-menu shadow-lg border-0 rounded-3 p-2 w-100">
                                @if (!SignInManager.IsSignedIn(User))
                                {
                                    <li class="p-3 text-center small">
                                        <p class="mb-2 text-muted">Влезте, за да добавяте в каталог.</p>
                                        <a href="/Identity/Account/Login" class="btn btn-sm btn-primary w-100 rounded-pill">Вход</a>
                                    </li>
                                }
                                else if (!userCatalogs.Any())
                                {
                                    <li class="p-3 text-center small">
                                        <p class="mb-2 text-muted">Нямате каталози.</p>
                                        <a asp-area="User" asp-controller="Catalogs" asp-action="Create" class="btn btn-sm btn-outline-primary w-100 rounded-pill">Създай първия</a>
                                    </li>
                                }
                                else
                                {
                                    foreach (var cat in userCatalogs)
                                    {
                                        var isInCatalog = item.CatalogDestinations.Any(cd => cd.CatalogId == cat.Id);
                                        <li>
                                            <form asp-area="User" asp-controller="Catalogs" asp-action="ToggleDestination" method="post">
                                                <input type="hidden" name="catalogId" value="@cat.Id" />
                                                <input type="hidden" name="destinationId" value="@item.Id" />
                                                <button type="submit" class="dropdown-item d-flex justify-content-between align-items-center rounded-2 py-2">
                                                    <span class="small">@cat.Name</span>
                                                    <i class="bi @(isInCatalog ? "bi-dash-circle-fill text-danger" : "bi-plus-circle-fill text-success")"></i>
                                                </button>
                                            </form>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a asp-area="User" asp-controller="Catalogs" asp-action="Create" class="dropdown-item text-primary fw-bold small">
                                            <i class="bi bi-plus-lg me-1"></i> Нов каталог
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>

                        <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                            <div class="small text-muted">Добавена на: @item.CreationDate.ToString("D")</div>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary rounded-pill px-3 fw-bold">Детайли</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div id="noResults" class="text-center py-5 d-none">
        <div class="bg-light d-inline-block p-4 rounded-circle mb-3">
            <i class="bi bi-search display-4 text-muted"></i>
        </div>
        <h4 class="fw-bold">Няма открити дестинации</h4>
        <p class="text-muted">Опитайте с друго име, автор или изчистете филтрите.</p>
        <button onclick="clearFilters()" class="btn btn-primary rounded-pill px-4">Изчисти филтрите</button>
    </div>
</div>

<style>
    .flashcard-hover {
        transition: 0.3s;
    }

        .flashcard-hover:hover {
            transform: translateY(-7px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    .object-fit-cover {
        object-fit: cover;
    }


    .glass-badge {
        background: rgba(0, 0, 0, 0.6);
        color: white;
        backdrop-filter: blur(4px);
        font-size: 0.7rem;
        border: none;
    }

    .tag-filter-btn.active {
        background-color: var(--bs-primary);
        color: white;
        border-color: var(--bs-primary);
    }
    .title-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 3rem; 
        line-height: 1.5rem;
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 2.5rem; 
        line-height: 1.25rem;
    }

    .destination-card {
        display: flex;
    }
</style>

<script>
    const searchInput = document.getElementById('searchInput');
    const cards = document.querySelectorAll('.destination-card');
    const noResults = document.getElementById('noResults');
    const tagBtns = document.querySelectorAll('.tag-filter-btn');

    searchInput.addEventListener('input', (e) => {
        filterContent(e.target.value.toLowerCase());
        updateActiveTag('none');
    });

    function filterByTag(tagName, btn) {
        searchInput.value = tagName;
        filterContent(tagName);
        updateActiveTag(tagName);
    }

    function filterContent(term) {
        let count = 0;
        cards.forEach(card => {
            const data = card.getAttribute('data-search');
            const match = data.includes(term);
            card.classList.toggle('d-none', !match);
            if (match) count++;
        });
        noResults.classList.toggle('d-none', count > 0);
    }

    function updateActiveTag(tagName) {
        tagBtns.forEach(btn => {
            btn.classList.toggle('active', btn.getAttribute('data-tag') === tagName);
        });
    }

    function clearFilters() {
        searchInput.value = '';
        filterContent('');
        updateActiveTag('all');
    }
</script>