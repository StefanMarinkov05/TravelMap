@model TravelMap.Models.Destination

@{
    ViewData["Title"] = Model.Name;
    var images = Model.Images?.ToList() ?? new List<TravelMap.Models.DestinationImage>();
}

<div class="container py-5">
    <div class="row g-4 mb-5">
        @* Секция със снимки (Carousel) *@
        <div class="col-lg-7">
            <div id="destCarousel" class="carousel slide rounded-4 overflow-hidden shadow-lg" data-bs-ride="carousel">
                @if (images.Count > 1)
                {
                    <div class="carousel-indicators">
                        @for (int i = 0; i < images.Count; i++)
                        {
                            <button type="button" data-bs-target="#destCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></button>
                        }
                    </div>
                }

                <div class="carousel-inner" style="height: 450px;">
                    @if (images.Any())
                    {
                        @for (int i = 0; i < images.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "") h-100">
                                <img src="@images[i].ImageUrl" class="d-block w-100 h-100 object-fit-cover" alt="@Model.Name">
                            </div>
                        }
                    }
                    else
                    {
                        <div class="carousel-item active h-100 bg-light d-flex align-items-center justify-content-center">
                            <img src="@Url.Content("~/images/destinations/default.jpg")"
                                 class="d-block w-100 h-100 object-fit-cover" alt="@Model.Name">
                        </div>
                    }
                </div>

                @if (images.Count > 1)
                {
                    <button class="carousel-control-prev" type="button" data-bs-target="#destCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon p-3 bg-dark bg-opacity-25 rounded-circle"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#destCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon p-3 bg-dark bg-opacity-25 rounded-circle"></span>
                    </button>
                }

                <div class="position-absolute top-0 start-0 m-3" style="z-index: 5;">
                    <span class="badge bg-primary px-3 py-2 rounded-pill shadow">@Model.Category?.Name</span>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="ps-lg-4 d-flex flex-column h-100">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-action="Index">Дестинации</a></li>
                        <li class="breadcrumb-item active">@Model.Country?.Name</li>
                    </ol>
                </nav>

                <h1 class="display-5 fw-bold text-dark mb-2">@Model.Name</h1>
                <p class="text-muted fs-5 mb-4">
                    <i class="bi bi-geo-alt-fill me-2 text-danger"></i>@Model.Region, @Model.Country?.Name
                </p>

                <div class="card border-0 bg-light rounded-4 mb-4 flex-grow-1">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3 text-primary"><i class="bi bi-info-circle me-2"></i>За дестинацията</h5>
                        <p class="text-secondary mb-0" style="text-align: justify; line-height: 1.6;">
                            @(string.IsNullOrEmpty(Model.Description) ? "Няма налично описание." : Model.Description)
                        </p>
                    </div>
                </div>

                @{
                    var authorName = Model.Author != null ? $"{Model.Author.FirstName} {Model.Author.LastName}" : "Система";
                }
                <div class="p-3 border rounded-4 bg-white d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-2 rounded-circle me-3">
                        <i class="bi bi-person-check text-primary fs-4"></i>
                    </div>
                    <div class="small">
                        <span class="text-muted d-block">Добавена от</span>
                        <strong class="text-dark">@authorName</strong>
                        <span class="text-muted ms-2">на @Model.CreationDate.ToString("dd MMM yyyy")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <hr class="my-5 opacity-25">

    <div class="row g-5">
        <div class="col-md-6 border-end-md">
            <div class="d-flex align-items-center mb-4">
                <div class="bg-primary p-2 rounded-3 me-3">
                    <i class="bi bi-calendar-event text-white fs-4"></i>
                </div>
                <h3 class="fw-bold mb-0">Предстоящи събития</h3>
            </div>

            @if (Model.Events != null && Model.Events.Any())
            {
                foreach (var ev in Model.Events)
                {
                    <div class="card mb-3 border-0 shadow-sm rounded-4 flashcard-item overflow-hidden">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="fw-bold mb-0 text-dark">@ev.Name</h5>
                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill">
                                    <i class="bi bi-clock me-1"></i> @ev.Date.ToString("dd.MM.yyyy")
                                </span>
                            </div>
                            <p class="text-muted small mb-3">@ev.Description</p>
                            <a asp-area="User" asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id"
                               class="btn btn-sm btn-outline-primary rounded-pill px-3">Детайли</a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-4 bg-light rounded-4">
                    <p class="text-muted mb-0">Няма регистрирани събития в момента.</p>
                </div>
            }
        </div>

        <div class="col-md-6 ps-md-5">
            <div class="d-flex align-items-center mb-4">
                <div class="bg-success p-2 rounded-3 me-3">
                    <i class="bi bi-journal-bookmark text-white fs-4"></i>
                </div>
                <h3 class="fw-bold mb-0">Статии и Пътеписи</h3>
            </div>

            @if (Model.Articles != null && Model.Articles.Any())
            {
                foreach (var art in Model.Articles)
                {
                    <div class="card mb-3 border-0 shadow-sm rounded-4 flashcard-item border-start border-success border-4">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-2">@art.Title</h5>
                            <p class="text-secondary small mb-3">
                                @(art.Description?.Length > 120 ? art.Description.Substring(0, 120) + "..." : art.Description)
                            </p>
                            <a asp-area="User" asp-controller="Articles" asp-action="Details" asp-route-id="@art.Id"
                               class="btn btn-sm btn-outline-success rounded-pill px-3">Прочети статията</a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-4 bg-light rounded-4">
                    <p class="text-muted mb-0">Все още няма написани статии за това място.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .object-fit-cover {
        object-fit: cover;
    }

    .flashcard-item {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .flashcard-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .breadcrumb-item a {
        text-decoration: none;
        color: #6c757d;
        font-weight: 500;
    }

    .breadcrumb-item.active {
        color: #0d6efd;
    }

    .carousel-indicators [button] {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: 2px solid #fff;
    }

    @@media (min-width: 768px) {
        .border-end-md {
            border-right: 1px solid rgba(0,0,0,0.1) !important;
        }
    }
</style>